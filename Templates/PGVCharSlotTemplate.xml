<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">
    <Frame name="PGVCharSlotTemplate" virtual="true" setAllPoints="true" mixin="PGVCharSlotTemplateMixin">
        <KeyValues>
            <KeyValue key="IsLeftSideSlot" type="boolean" value="false"/>
            <KeyValue key="IsBottomSlot" type="boolean" value="false"/>
        </KeyValues>
        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="ItemLevel" inherits="GameTooltipText" text="" hidden="true"/>
                <FontString parentKey="UpgradeTrack" inherits="GameTooltipText" text="" hidden="true"/>
                <FontString parentKey="Gems" inherits="GameTooltipText" text="" hidden="true"/>
                <FontString parentKey="Enchant" inherits="GameTooltipText" text="" hidden="true"/>
                <FontString parentKey="Durability" inherits="GameTooltipText" text="" hidden="true"/>
            </Layer>
            <Layer level="ARTWORK">
                <Texture parentKey="EmbellishmentShadow" file="Interface/Buttons/WHITE8x8" setAllPoints="true" hidden="true">
                    <Color color="BLACK_FONT_COLOR" a="0.3"/>
                </Texture>
                <Texture parentKey="Embellishment" file="Interface/LootFrame/Toast-Star" hidden="true">
                    <Size x="21" y="21"/>
                    <Color r="0" g="1" b="0.6"/>
                    <Scripts>
                        <OnShow method="OnShowEmbellishment"/>
                        <OnHide method="OnHideEmbellishment"/>
                    </Scripts>
                </Texture>
            </Layer>
        </Layers>
        <Frames>
            <StatusBar parentKey="DurabilityBarBg" inherits="TextStatusBar" hidden="true" defaultValue="100" minValue="0" maxValue="100">
                <Size y="6.5"/>
                <Anchors>
                    <Anchor point="LEFT" relativePoint="BOTTOMLEFT" x="2" y="6"/>
                    <Anchor point="RIGHT" relativePoint="BOTTOMRIGHT" x="-2" y="6"/>
                </Anchors>
                <BarTexture file="Interface/Buttons/WHITE8x8"/>
                <BarColor r="0.8" g="0.8" b="0.8"/>
            </StatusBar>
            <StatusBar parentKey="DurabilityBar" inherits="TextStatusBar" hidden="true" enableMouse="true" minValue="0" maxValue="100">
                <Size y="6.5"/>
                <Anchors>
                    <Anchor point="LEFT" relativePoint="BOTTOMLEFT" x="2" y="6"/>
                    <Anchor point="RIGHT" relativePoint="BOTTOMRIGHT" x="-2" y="6"/>
                </Anchors>
                <BarTexture file="Interface/TARGETINGFRAME/UI-StatusBar"/>
                <Scripts>
                    <OnShow method="OnShowDurabilityBar"/>
                    <OnHide method="OnHideDurabilityBar"/>
                </Scripts>
            </StatusBar>
        </Frames>
        <Scripts>
            <OnLoad method="OnLoad"/>
        </Scripts>
    </Frame>
</Ui>