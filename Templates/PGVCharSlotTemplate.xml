<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">
    <Frame name="PGVCharSlotTemplate" virtual="true" mixin="PGVCharSlotTemplateMixin">
        <KeyValues>
            <KeyValue key="IsLeftSideSlot" type="boolean" value="false"/>
            <KeyValue key="IsBottomSlot" type="boolean" value="false"/>
        </KeyValues>
        <Anchors>
            <Anchor point="TOPLEFT"/>
            <Anchor point="BOTTOMRIGHT"/>
        </Anchors>
        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="ItemLevel" inherits="GameTooltipText" text="" hidden="true"/>
                <FontString parentKey="UpgradeTrack" inherits="GameTooltipText" text="" hidden="true"/>
                <FontString parentKey="Gems" inherits="GameTooltipText" text="" hidden="true"/>
                <FontString parentKey="Enchant" inherits="GameTooltipText" text="" hidden="true"/>
                <FontString parentKey="Durability" inherits="GameTooltipText" text="" hidden="true"/>
            </Layer>
            <Layer level="ARTWORK">
                <Texture parentKey="EmbellishmentShadow" file="Interface/Buttons/WHITE8x8" setAllPoints="true" hidden="true">
                    <Color color="BLACK_FONT_COLOR" a="0.3"/>
                </Texture>
                <Texture parentKey="Embellishment" file="Interface/LootFrame/Toast-Star" setAllPoints="true" hidden="true">
                    <Size x="25" y="25"/>
                    <Color r="0" g="1" b="0.6" a="1"/>
                </Texture>
            </Layer>
        </Layers>
        <Frames>
            <StatusBar parentKey="DurabilityBarBg" inherits="TextStatusBar" hidden="true"/>
            <StatusBar parentKey="DurabilityBar" inherits="TextStatusBar" hidden="true"/>
        </Frames>
        <Scripts>
            <OnLoad method="OnLoad"/>
        </Scripts>
    </Frame>
</Ui>